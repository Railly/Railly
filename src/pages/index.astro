---
import { getCollection } from "astro:content";
import { ogUrl, siteConfig } from "@/config/site";
import { achievements } from "@/data/achievements";
import { featuredProjects } from "@/data/projects";
import Hack0Logo from "../assets/svgs/h0-logo.svg";
import Text0Logo from "../assets/svgs/t0-logo.svg";
import PremiereCountdown from "../components/blog/PremiereCountdown";
import ViewCounter from "../components/blog/ViewCounter";
import AgentfilesLogo from "../components/brand/AgentfilesLogo.astro";
import ElementsLogo from "../components/brand/ElementsLogo.astro";
import OneHunterLogo from "../components/brand/OneHunterLogo.astro";
import ScrapiLogo from "../components/brand/ScrapiLogo.astro";
import TinteLogo from "../components/brand/TinteLogo.astro";
import TrxLogo from "../components/brand/TrxLogo.astro";
import AchievementRow from "../components/home/AchievementRow.astro";
import FeaturedProjectRow from "../components/home/FeaturedProjectRow.astro";
import Footer from "../components/layout/Footer.astro";
import HeroSection from "../components/layout/HeroSection.astro";
import PageLayout from "../components/layout/PageLayout.astro";
import SectionHeader from "../components/layout/SectionHeader.astro";
import NewsletterSection from "../components/newsletter/NewsletterSection.astro";
import { isPostListable } from "../config/blog";
import Layout from "../layouts/Layout.astro";

const ogImage = ogUrl({
	title: "Railly Hugo",
	description:
		"AI Software Engineer at Clerk, Founder of Crafter Station. Lima, Peru.",
});

const allPosts = await getCollection("blog", ({ data }) =>
	import.meta.env.PROD ? data.status !== "draft" : true,
);
const activePosts = allPosts
	.filter(({ data }) => isPostListable(data))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = activePosts.slice(0, 5);
const postsByYear = recentPosts.reduce(
	(acc, post) => {
		const year = post.data.pubDate.getFullYear();
		if (!acc[year]) {
			acc[year] = [];
		}
		acc[year].push(post);
		return acc;
	},
	{} as Record<number, typeof recentPosts>,
);
const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);
const newestPost = activePosts[0];
const isNewest = (slug: string) => slug === newestPost?.slug;
const formatDate = (date: Date) =>
	`${date.getDate().toString().padStart(2, "0")}/${(date.getMonth() + 1).toString().padStart(2, "0")}`;
const iconMap = {
	elements: ElementsLogo,
	text0: Text0Logo,
	tinte: TinteLogo,
	oneHunter: OneHunterLogo,
	scrapi: ScrapiLogo,
	hack0: Hack0Logo,
	agentfiles: AgentfilesLogo,
	trx: TrxLogo,
} as const;
type IconKey = keyof typeof iconMap;
---

<Layout
	title="Railly Hugo - AI Software Engineer | Crafter Station Founder"
	description="AI Software Engineer at Clerk and Founder of Crafter Station. Building open-source developer tools, winning hackathons, and growing Peru's tech ecosystem from Lima."
	image={ogImage}
>
	<PageLayout class="flex flex-col gap-10">
		<HeroSection name={siteConfig.name} title={siteConfig.hero.title} />

		<section class="w-full">
			<div class="mb-4 flex items-center justify-between">
				<SectionHeader title="Projects" className="mb-0" />
				<a href="/projects" class="group text-xs text-foreground-3 transition-colors duration-200 hover:text-foreground-2">
					<span class="flex items-center gap-1">
						<span>view all</span>
						<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 12h15m0 0-5.625-6m5.625 6-5.625 6"></path></svg>
					</span>
				</a>
			</div>
			<div class="space-y-0">
				{featuredProjects.map((project) => <FeaturedProjectRow project={project} IconComponent={iconMap[project.icon as IconKey]} />)}
			</div>
		</section>

		<section class="w-full">
			<div class="mb-4 flex items-center justify-between">
				<SectionHeader title="Writing" className="mb-0" />
				<a href="/writing" class="group text-xs text-foreground-3 transition-colors duration-200 hover:text-foreground-2">
					<span class="flex items-center gap-1">
						<span>view all</span>
						<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 12h15m0 0-5.625-6m5.625 6-5.625 6"></path></svg>
					</span>
				</a>
			</div>
			<div class="space-y-0">
				{years.map((year) => postsByYear[year].map((post, index) => {
					const isPremiere = post.data.status === "premiere" && new Date() < post.data.pubDate;
					const Element = isPremiere ? "div" : "a";
					return (
						<Element {...(!isPremiere ? { href: `/blog/${post.slug}` } : {})} class:list={["group -mx-3 flex items-baseline gap-4 border-b border-ui px-3 py-3 transition-colors", isPremiere ? "cursor-default" : "hover:bg-background-2"]}>
							<span class="w-12 shrink-0 text-sm tabular-nums text-foreground-3">{index === 0 ? year : ""}</span>
							<span class:list={["flex-1 text-sm font-medium", isPremiere ? "text-foreground-3" : "text-foreground group-hover:text-foreground"]}>
								{post.data.title}
								{isPremiere ? (
									<span class="ml-2 rounded border border-ui px-1.5 py-0.5 text-xs font-normal text-foreground-3">Premiere</span>
								) : isNewest(post.slug) ? (
									<span class="ml-2 rounded bg-ui px-1.5 py-0.5 text-xs font-normal text-foreground-2">Newest</span>
								) : null}
							</span>
							{isPremiere ? (
								<PremiereCountdown pubDate={post.data.pubDate.toISOString()} client:only="react" />
							) : (
								<>
									<ViewCounter slug={post.slug} client:only="react" className="shrink-0 text-xs tabular-nums text-foreground-3" />
									<span class="shrink-0 text-sm tabular-nums text-foreground-3">{formatDate(post.data.pubDate)}</span>
								</>
							)}
						</Element>
					);
				}))}
				{recentPosts.length === 0 && <div class="py-12 text-center"><p class="text-foreground-2">More stories coming soon</p></div>}
			</div>
		</section>

		<section class="w-full">
			<div class="mb-4">
				<SectionHeader title="Achievements" className="mb-0" />
			</div>
			<div class="space-y-0">
				{achievements.map((item, index) => <AchievementRow item={item} showYear={item.year !== achievements[index - 1]?.year} />)}
			</div>
		</section>

		<NewsletterSection />
		<Footer />
	</PageLayout>
</Layout>
