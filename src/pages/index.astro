---
import { getCollection } from "astro:content";
import HomeAchievementsList from "../components/home/HomeAchievementsList.astro";
import HomeProjectsList from "../components/home/HomeProjectsList.astro";
import HomeWritingList from "../components/home/HomeWritingList.astro";
import Footer from "../components/layout/Footer.astro";
import HeroSection from "../components/layout/HeroSection.astro";
import PageLayout from "../components/layout/PageLayout.astro";
import SectionHeader from "../components/layout/SectionHeader.astro";
import NewsletterSection from "../components/newsletter/NewsletterSection.astro";
import SectionLink from "../components/ui/SectionLink.astro";
import { isPostListable } from "../config/blog";
import { ogUrl, siteConfig } from "../config/site";
import Layout from "../layouts/Layout.astro";

const ogTitle = "Railly Hugo";
const ogDescription =
	"AI Software Engineer at Clerk, Founder of Crafter Station. Lima, Peru.";
const ogImage = ogUrl({ title: ogTitle, description: ogDescription });
const allPosts = await getCollection("blog", ({ data }) =>
	import.meta.env.PROD ? data.status !== "draft" : true,
);
const activePosts = allPosts
	.filter(({ data }) => isPostListable(data))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = activePosts.slice(0, 5);
const postsByYear = recentPosts.reduce(
	(acc, post) => {
		const year = post.data.pubDate.getFullYear();
		if (!acc[year]) acc[year] = [];
		acc[year].push(post);
		return acc;
	},
	{} as Record<number, typeof recentPosts>,
);
const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);
const newestPost = activePosts[0];
const isNewest = (slug: string) => slug === newestPost?.slug;
const formatDate = (date: Date) =>
	`${date.getDate().toString().padStart(2, "0")}/${(date.getMonth() + 1).toString().padStart(2, "0")}`;
---

<Layout
	title="Railly Hugo - AI Software Engineer | Crafter Station Founder"
	description={siteConfig.description}
	image={ogImage}
>
	<PageLayout class="flex flex-col gap-10">
		<HeroSection name={siteConfig.name} title={siteConfig.hero.title} />

		<section class="w-full">
			<SectionLink title="Projects" href="/projects" />
			<HomeProjectsList />
		</section>

		<section class="w-full">
			<SectionLink title="Writing" href="/writing" />
			<HomeWritingList
				years={years}
				postsByYear={postsByYear}
				isNewest={isNewest}
				formatDate={formatDate}
			/>
			{recentPosts.length === 0 && (
				<div class="py-12 text-center">
					<p class="text-foreground-2">More stories coming soon</p>
				</div>
			)}
		</section>

		<section class="w-full">
			<div class="mb-4">
				<SectionHeader title="Achievements" className="mb-0" />
			</div>
			<HomeAchievementsList />
		</section>

		<NewsletterSection />
		<Footer />
	</PageLayout>
</Layout>
