import RoastRouletteLogo from "../components/brand/RoastRouletteLogo.astro";
import ScrapiLogo from "../components/brand/ScrapiLogo.astro";
import SkillKitLogo from "../components/brand/SkillKitLogo.astro";
import SkillsLogo from "../components/brand/SkillsLogo.astro";
import SpotiCliLogo from "../components/brand/SpotiCliLogo.astro";
import SunatCliLogo from "../components/brand/SunatCliLogo.astro";
