---
import { ogUrl } from "@/config/site";
import { projects as projectsData } from "@/data/projects";
import BrandIcon from "../components/brand/BrandIcon.astro";
import Footer from "../components/layout/Footer.astro";
import PageLayout from "../components/layout/PageLayout.astro";
import SectionHeader from "../components/layout/SectionHeader.astro";
import Layout from "../layouts/Layout.astro";

const ogTitle = "Projects";
const ogDescription =
	"Open source developer tools by Railly Hugo: Tinte, Elements, Agentfiles, trx, and more.";
const ogImage = ogUrl({
	title: ogTitle,
	description: ogDescription,
	tag: "projects",
});

async function getStars(repo: string): Promise<number> {
	try {
		const res = await fetch(`https://api.github.com/repos/${repo}`);
		if (!res.ok) return 0;
		const data = await res.json();
		return data.stargazers_count || 0;
	} catch {
		return 0;
	}
}

const projects = await Promise.all(
	projectsData.map(async (project) => ({
		...project,
		stars: project.repo ? await getStars(project.repo) : 0,
		github: project.repo ? `https://github.com/${project.repo}` : undefined,
	})),
);

projects.sort((a, b) => b.stars - a.stars);
---

<Layout title="Projects - Railly Hugo" description={ogDescription} image={ogImage}>
	<PageLayout class="flex flex-col gap-8">
		<SectionHeader title="Projects" />

		<div class="-mx-3 overflow-x-auto">
			<table class="w-full text-sm">
				<thead>
					<tr class="border-b border-ui">
						<th class="px-3 py-3 text-left text-xs font-medium uppercase tracking-wider text-foreground-3">
							Name
						</th>
						<th class="px-3 py-3 text-left text-xs font-medium uppercase tracking-wider text-foreground-3">
							Stars
						</th>
						<th class="hidden px-3 py-3 text-left text-xs font-medium uppercase tracking-wider text-foreground-3 sm:table-cell">
							Description
						</th>
						<th class="px-3 py-3 text-left text-xs font-medium uppercase tracking-wider text-foreground-3">
							Links
						</th>
					</tr>
				</thead>
				<tbody>
					{
						projects.map((project) => (
							<tr class="border-b border-ui transition-colors hover:bg-background-2">
								<td class="px-3 py-3">
									<div class="flex items-center gap-2">
										<span class="flex h-5 w-5 shrink-0 items-center justify-center">
											<BrandIcon
												name={project.icon}
												width={16}
												height={16}
												class="text-foreground-2"
											/>
										</span>
										<span class="font-medium text-foreground">
											{project.name}
										</span>
									</div>
								</td>
									<td class="px-3 py-3">
										<span class="flex items-center gap-1 text-foreground-2">
											<svg
												width="14"
												height="14"
												viewBox="0 0 24 24"
												fill="currentColor"
												class="text-foreground-3"
											>
												<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
											</svg>
											{project.stars}
										</span>
									</td>
									<td class="hidden max-w-xs px-3 py-3 text-foreground-2 sm:table-cell">
										{project.description}
									</td>
									<td class="px-3 py-3">
										<div class="flex items-center gap-3">
											{project.github && (
												<a
													href={project.github}
													target="_blank"
													rel="noopener noreferrer"
													class="text-foreground-3 transition-colors hover:text-foreground"
													title="GitHub"
												>
													<svg
														width="16"
														height="16"
														viewBox="0 0 24 24"
														fill="currentColor"
													>
														<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
													</svg>
												</a>
											)}
											<a
												href={project.url}
												target="_blank"
												rel="noopener noreferrer"
												class="text-foreground-3 transition-colors hover:text-foreground"
												title="Visit site"
											>
												<svg
													width="16"
													height="16"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
													<polyline points="15 3 21 3 21 9" />
													<line x1="10" y1="14" x2="21" y2="3" />
												</svg>
											</a>
										</div>
									</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>

		<Footer />
	</PageLayout>
</Layout>
