const ogTitle = "Projects";
const ogDescription = "Open source developer tools by Railly Hugo: Tinte, Elements, Agentfiles, trx, and more.";
const ogImage = `/api/og?title=${encodeURIComponent(ogTitle)}&description=${encodeURIComponent(ogDescription)}&tag=projects`;

