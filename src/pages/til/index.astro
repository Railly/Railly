---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageLayout from "../../components/layout/PageLayout.astro";
import Link from "../../components/content/Link.astro";
import TilFilters from "../../components/til/TilFilters.tsx";
import TilShareLink from "../../components/til/TilShareLink.tsx";

const tils = await getCollection("til", ({ data }) => {
	return import.meta.env.PROD ? data.status === "published" : true;
});

const sortedTils = tils.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const tilsWithContent = await Promise.all(
	sortedTils.map(async (til) => {
		const { Content } = await render(til);
		return { til, Content };
	}),
);

const topics = [...new Set(sortedTils.map((t) => t.data.topic))].sort();

const formatDate = (date: Date) => {
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
};

const formatDateShort = (date: Date) => {
	return date.toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
	});
};
---

<Layout
	title="Today I Learned - Railly Hugo"
	description="Quick daily learnings on AI, infrastructure, design, and shipping from an AI Software Engineer in Lima, Peru."
>
	<PageLayout>
		<nav
			slot="rightSidebar"
			class="sticky top-24 w-40 ml-auto hidden lg:block opacity-65 hover:opacity-100 transition-opacity duration-300 text-right"
			id="til-toc"
		>
			<div class="text-xs uppercase tracking-wider text-foreground-3 mb-4">
				Index
			</div>
			<ul class="space-y-0.5 text-xs border-r border-ui">
				{
					sortedTils.map((til) => (
						<li>
							<a
								href={`#${til.id.replace(/\.mdx?$/, "")}`}
								class="toc-link block py-1 px-3 border-r-2 -mr-px transition-all duration-200 border-transparent text-foreground-3 hover:text-foreground hover:border-ui-2"
								data-heading={til.id.replace(/\.mdx?$/, "")}
								title={til.data.title}
							>
								<time
									datetime={til.data.pubDate.toISOString()}
									class="tabular-nums tracking-tight"
								>
									{formatDateShort(til.data.pubDate)}
								</time>
							</a>
						</li>
					))
				}
			</ul>
		</nav>
		<h1 class="text-3xl font-medium text-foreground mb-4">TIL</h1>
		<p class="text-foreground-2 mb-8 text-[15px]">
			Learning new things every day. Writing them down to remember.
		</p>
		<TilFilters topics={topics} client:load />
		<div class="space-y-12">
			{
				tilsWithContent.map(({ til, Content }) => (
					<article class="group" id={til.id.replace(/\.mdx?$/, "")} data-topic={til.data.topic}>
						<div class="flex items-center gap-2 mb-2">
							<time
								datetime={til.data.pubDate.toISOString()}
								class="text-sm text-foreground-3"
							>
								{formatDate(til.data.pubDate)}
							</time>
							<span class="text-foreground-3">·</span>
							<span class="text-xs text-foreground-3">
								#{til.data.topic}
							</span>
							<span class="text-foreground-3">·</span>
							<TilShareLink slug={til.id.replace(/\.mdx?$/, "")} client:load />
						</div>
						<h2 class="text-lg font-medium text-foreground mb-3">
							{til.data.title}
						</h2>
						<div class="prose prose-theme prose-sm max-w-none text-foreground-2 prose-p:text-[15px] prose-p:leading-[1.75] prose-a:text-foreground-2 prose-a:underline prose-a:decoration-foreground-3/50 prose-a:underline-offset-2 prose-a:decoration-1 prose-a:hover:text-foreground prose-a:hover:decoration-foreground prose-a:transition-colors prose-code:before:content-none prose-code:after:content-none prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:rounded">
							<Content components={{ a: Link }} />
						</div>
						{til.data.link && (
							<a
								href={til.data.link}
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex items-center gap-1 text-sm text-foreground-3 hover:text-foreground transition-colors mt-3"
							>
								Learn more
								<svg
									width="12"
									height="12"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									viewBox="0 0 24 24"
								>
									<path
										d="M4.5 12h15m0 0-5.625-6m5.625 6-5.625 6"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</a>
						)}
					</article>
				))
			}
		</div>
	</PageLayout>
<style>
		article {
			scroll-margin-top: 6rem;
		}

		.prose :global(strong) {
			color: var(--color-foreground);
			font-weight: 600;
		}

		.prose :global(:not(pre) > code) {
			background-color: var(--color-background-2);
			padding: 0.125rem 0.375rem;
			font-size: 0.875rem;
			border-radius: 0.25rem;
			color: var(--color-foreground);
		}

		.prose :global(pre > code) {
			display: block;
		}

		.prose :global(pre > code::before),
		.prose :global(pre > code::after) {
			content: none;
		}

		.prose :global(a[href^="http"])::after {
			content: "↗";
			margin-left: 0.125rem;
			font-size: 0.75em;
		}
	</style>
	<script>
		function setupTilToc() {
			const toc = document.getElementById("til-toc");
			if (!toc) return;

			const tocLinks = toc.querySelectorAll(".toc-link");
			const sections = Array.from(tocLinks)
				.map((link) => {
					const slug = link.getAttribute("data-heading");
					return slug ? document.getElementById(slug) : null;
				})
				.filter((s): s is HTMLElement => s !== null);

			let currentActive: Element | null = null;

			function setActiveLink(link: Element | null) {
				if (currentActive === link) return;
				if (currentActive) {
					currentActive.classList.remove(
						"border-foreground",
						"text-foreground",
						"font-semibold",
					);
					currentActive.classList.add(
						"border-transparent",
						"text-foreground-3",
					);
				}
				if (link) {
					link.classList.remove("border-transparent", "text-foreground-2");
					link.classList.add(
						"border-foreground",
						"text-foreground",
						"font-semibold",
					);
				}
				currentActive = link;
			}

			tocLinks.forEach((link) => {
				link.addEventListener("click", (e) => {
					e.preventDefault();
					const slug = link.getAttribute("data-heading");
					const target = slug ? document.getElementById(slug) : null;
					if (target) {
						target.scrollIntoView({ behavior: "smooth", block: "start" });
						setActiveLink(link);
						history.pushState(null, "", `#${slug}`);
					}
				});
			});

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							const slug = entry.target.id;
							const link = toc.querySelector(`[data-heading="${slug}"]`);
							setActiveLink(link);
						}
					});
				},
				{ rootMargin: "-80px 0px -70% 0px", threshold: 0 },
			);
			sections.forEach((section) => observer.observe(section));

			if (window.location.hash) {
				const slug = window.location.hash.slice(1);
				const link = toc.querySelector(`[data-heading="${slug}"]`);
				setActiveLink(link);
			} else if (sections.length > 0) {
				setActiveLink(toc.querySelector(".toc-link"));
			}
		}

		setupTilToc();
		document.addEventListener("astro:page-load", setupTilToc);
	</script>
</Layout>
