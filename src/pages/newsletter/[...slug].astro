---
import { type CollectionEntry, getCollection } from "astro:content";
import Link from "../../components/content/Link.astro";
import Quote from "../../components/content/Quote.astro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const issues = await getCollection("newsletter");
	return issues.map((issue) => ({
		params: { slug: issue.slug },
		props: { issue },
	}));
}

interface Props {
	issue: CollectionEntry<"newsletter">;
}

const { issue } = Astro.props;
const { Content } = await issue.render();

const publishedDate = issue.data.pubDate.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const ogImage = `/api/og?title=${encodeURIComponent(issue.data.title)}&description=${encodeURIComponent(issue.data.subject)}&tag=newsletter`;
---

<Layout
    title={`${issue.data.title} - Newsletter`}
    description={issue.data.subject}
    image={ogImage}
>
    <div class="w-full mx-auto py-12 sm:py-24">
        <div class="max-w-[83rem] mx-auto px-4 sm:px-6 lg:grid lg:grid-cols-[1fr_minmax(0,_2.5fr)_1fr] lg:gap-8">
            <div class="lg:col-start-1"></div>

            <div class="lg:col-start-2">
                <header class="mb-10">
                    <div class="flex items-center gap-2 mb-4">
                        <a
                            href="/newsletter"
                            class="text-xs text-foreground-3 hover:text-foreground-2 transition-colors"
                        >
                            Newsletter
                        </a>
                        <span class="text-foreground-3 text-xs">/</span>
                        <span class="text-xs text-foreground-3 font-mono">
                            #{issue.data.weekNumber}
                        </span>
                    </div>
                    <h1 class="text-2xl font-semibold tracking-[-0.03em] mb-5 text-foreground" style="text-wrap: balance;">
                        {issue.data.title}
                    </h1>
                    <div class="flex items-center gap-4 text-sm text-foreground-3">
                        <time datetime={issue.data.pubDate.toISOString()}>
                            {publishedDate}
                        </time>
                    </div>
                </header>

                <article>
                    <div
                        class:list={[
                            "prose prose-theme max-w-none",
                            "prose-headings:text-foreground prose-headings:font-semibold prose-headings:scroll-mt-10 prose-headings:tracking-[-0.02em]",
                            "prose-h2:text-lg prose-h2:mt-12 prose-h2:mb-4",
                            "prose-h3:text-base prose-h3:mt-8 prose-h3:mb-3 prose-h3:font-medium",
                            "prose-p:text-foreground-2 prose-p:text-[15px] prose-p:leading-[1.75] prose-p:tracking-[-0.01em] prose-p:[text-wrap:pretty]",
                            "prose-a:text-foreground-2 prose-a:underline prose-a:decoration-foreground-3/50 prose-a:underline-offset-2 prose-a:decoration-1 prose-a:hover:text-foreground prose-a:hover:decoration-foreground prose-a:transition-colors",
                            "prose-strong:text-foreground/90 prose-strong:font-medium",
                            "prose-li:text-foreground-2 prose-li:text-[15px] prose-li:leading-[1.75] prose-li:tracking-[-0.01em]",
                            "prose-li:marker:text-foreground-3",
                            "prose-ul:my-5 prose-ul:space-y-1",
                            "prose-ol:my-5 prose-ol:space-y-1",
                            "prose-hr:border-ui/50 prose-hr:my-10",
                            "dark:prose-invert",
                        ]}
                    >
                        <Content components={{ blockquote: Quote, a: Link }} />
                    </div>
                </article>

                <div class="mt-16 pt-8 border-t border-ui">
                    <a
                        href="/newsletter"
                        class="text-sm text-foreground-3 hover:text-foreground-2 transition-colors"
                    >
                        &larr; All issues
                    </a>
                </div>
            </div>

            <div class="lg:col-start-3"></div>
        </div>
    </div>
</Layout>
