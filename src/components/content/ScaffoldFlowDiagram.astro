    <text x="70" y="50" text-anchor="middle" fill="var(--color-background-2)" font-size="9" font-family="ui-sans-serif, system-ui" opacity="0.7">name + framework</text>

    <line x1="130" y1="38" x2="158" y2="38" stroke="var(--color-foreground-3)" stroke-width="1.5" marker-end="url(#sfArrowR)" />

    <rect x="166" y="16" width="110" height="44" rx="8" fill="var(--color-background-2)" stroke="var(--color-ui)" stroke-width="1.5" />
    <text x="221" y="34" text-anchor="middle" fill="var(--color-foreground)" font-size="11" font-weight="500" font-family="ui-monospace, monospace">Next.js + Biome</text>
