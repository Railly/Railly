---
<div class="scaffold-flow-diagram my-8 overflow-x-auto">
  <svg viewBox="0 0 780 80" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[780px] mx-auto">
    <defs>
      <marker id="sfArrowR" viewBox="0 0 10 7" refX="9" refY="3.5" markerWidth="8" markerHeight="6" orient="0">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="var(--color-foreground-3)" />
      </marker>
    </defs>

    <rect x="10" y="16" width="120" height="44" rx="8" fill="var(--color-foreground)" stroke="var(--color-foreground)" stroke-width="1.5" />
