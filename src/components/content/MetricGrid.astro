---
interface Metric {
	value: string;
	label: string;
	detail?: string;
}

interface Props {
	items: Metric[];
}

const { items } = Astro.props;
---

<div class="not-prose my-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
	{items.map((item) => (
		<div class="rounded-xl border border-ui/70 bg-background-2/45 px-4 py-4">
			<p class="font-mono text-xl font-medium tracking-[-0.04em] text-foreground">
				{item.value}
			</p>
			<p class="mt-1 text-sm font-medium text-foreground-2">{item.label}</p>
			{item.detail && <p class="mt-1 text-xs leading-relaxed text-foreground-3">{item.detail}</p>}
		</div>
	))}
</div>
