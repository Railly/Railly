---
---
<div class="core-loop-diagram my-8 overflow-x-auto">
  <svg viewBox="0 0 780 320" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[780px] mx-auto">
    <defs>
      <marker id="clArrowR" viewBox="0 0 10 7" refX="9" refY="3.5" markerWidth="8" markerHeight="6" orient="0">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="var(--color-flexoki-tx-3)" />
      </marker>
      <marker id="clArrowD" viewBox="0 0 7 10" refX="3.5" refY="9" markerWidth="6" markerHeight="8" orient="0">
        <path d="M 0 0 L 3.5 10 L 7 0 z" fill="var(--color-flexoki-tx-3)" />
      </marker>
      <marker id="clArrowL" viewBox="0 0 10 7" refX="1" refY="3.5" markerWidth="8" markerHeight="6" orient="0">
        <path d="M 10 0 L 0 3.5 L 10 7 z" fill="var(--color-flexoki-tx-3)" />
      </marker>
      <marker id="clArrowU" viewBox="0 0 7 10" refX="3.5" refY="1" markerWidth="6" markerHeight="8" orient="0">
        <path d="M 0 10 L 3.5 0 L 7 10 z" fill="var(--color-flexoki-tx-3)" />
      </marker>
    </defs>

    <!-- ═══ ROW 1: Morning (y=20) ═══ -->
    <text x="20" y="18" fill="var(--color-flexoki-tx-3)" font-size="10" font-family="ui-sans-serif, system-ui" font-weight="500" letter-spacing="0.05em">AM</text>

    <rect x="20" y="28" width="110" height="44" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="75" y="48" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/morning</text>
    <text x="75" y="63" text-anchor="middle" fill="var(--color-flexoki-bg-2)" font-size="9" font-family="ui-sans-serif, system-ui" opacity="0.7">3 MITs for the day</text>

    <line x1="130" y1="50" x2="168" y2="50" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#clArrowR)" />

    <rect x="176" y="28" width="140" height="44" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="246" y="48" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="11" font-weight="500" font-family="ui-sans-serif, system-ui">Calendar + Tasks</text>
    <text x="246" y="63" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">focused before code</text>

    <!-- ═══ ROW 2: During the day (y=110) ═══ -->
    <text x="20" y="108" fill="var(--color-flexoki-tx-3)" font-size="10" font-family="ui-sans-serif, system-ui" font-weight="500" letter-spacing="0.05em">WORK</text>

    <rect x="20" y="118" width="80" height="44" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="60" y="144" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/ship</text>

    <rect x="114" y="118" width="72" height="44" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="150" y="144" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/log</text>

    <line x1="186" y1="140" x2="218" y2="140" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#clArrowR)" />

    <rect x="226" y="118" width="120" height="44" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="286" y="136" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">02_Journal/</text>
    <text x="286" y="152" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">auto-logged</text>

    <line x1="346" y1="140" x2="388" y2="140" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#clArrowR)" />

    <rect x="396" y="118" width="100" height="44" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="446" y="138" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/inbox</text>
    <text x="446" y="153" text-anchor="middle" fill="var(--color-flexoki-bg-2)" font-size="9" font-family="ui-sans-serif, system-ui" opacity="0.7">process clips</text>

    <line x1="496" y1="140" x2="528" y2="140" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#clArrowR)" />

    <rect x="536" y="118" width="120" height="44" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="596" y="136" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">03_Garden/</text>
    <text x="596" y="152" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">atomic notes</text>

    <!-- ═══ ROW 3: End of day (y=200) ═══ -->
    <text x="20" y="198" fill="var(--color-flexoki-tx-3)" font-size="10" font-family="ui-sans-serif, system-ui" font-weight="500" letter-spacing="0.05em">PM</text>

    <rect x="20" y="208" width="120" height="44" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="80" y="228" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/close-day</text>
    <text x="80" y="243" text-anchor="middle" fill="var(--color-flexoki-bg-2)" font-size="9" font-family="ui-sans-serif, system-ui" opacity="0.7">review + plan</text>

    <line x1="140" y1="230" x2="178" y2="230" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#clArrowR)" />

    <rect x="186" y="208" width="180" height="44" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="276" y="228" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="11" font-weight="500" font-family="ui-sans-serif, system-ui">Learnings + carry-over</text>
    <text x="276" y="243" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">tomorrow prep</text>

    <!-- ═══ ROW 4: Weekly (y=290) ═══ -->
    <text x="20" y="288" fill="var(--color-flexoki-tx-3)" font-size="10" font-family="ui-sans-serif, system-ui" font-weight="500" letter-spacing="0.05em">WEEKLY</text>

    <rect x="20" y="296" width="90" height="44" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="65" y="316" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/pulse</text>
    <text x="65" y="331" text-anchor="middle" fill="var(--color-flexoki-bg-2)" font-size="9" font-family="ui-sans-serif, system-ui" opacity="0.7">Pareto analysis</text>

    <line x1="110" y1="318" x2="148" y2="318" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#clArrowR)" />

    <rect x="156" y="296" width="130" height="44" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="221" y="316" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="11" font-weight="500" font-family="ui-sans-serif, system-ui">Goal alignment</text>
    <text x="221" y="331" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">drift + blind spots</text>

    <line x1="286" y1="318" x2="318" y2="318" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#clArrowR)" />

    <rect x="326" y="296" width="160" height="44" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="406" y="316" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="11" font-weight="500" font-family="ui-sans-serif, system-ui">Anti-pattern checks</text>
    <text x="406" y="331" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">warns on old mistakes</text>

    <!-- Cycle arrow: Weekly → back to Morning (right side loop) -->
    <path d="M 486 318 L 740 318 L 740 50 L 316 50" stroke="var(--color-flexoki-tx-3)" stroke-width="1" stroke-dasharray="6 3" fill="none" marker-end="url(#clArrowL)" />
    <text x="752" y="186" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui" font-style="italic" writing-mode="tb" text-anchor="middle">repeat</text>

  </svg>
</div>

<style>
  .core-loop-diagram {
    -webkit-overflow-scrolling: touch;
  }
  .core-loop-diagram svg text {
    user-select: none;
  }
</style>
