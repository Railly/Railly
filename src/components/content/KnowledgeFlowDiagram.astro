---
---
<div class="knowledge-flow-diagram my-8 overflow-x-auto">
  <svg viewBox="0 0 820 340" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[820px] mx-auto">
    <defs>
      <marker id="arrow" viewBox="0 0 10 7" refX="9" refY="3.5" markerWidth="8" markerHeight="6" orient="auto-start-auto">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="var(--color-flexoki-tx-3)" />
      </marker>
    </defs>

    <!-- ═══ ROW 1: Main capture flow (y=30) ═══ -->

    <!-- Web Clipper -->
    <rect x="10" y="30" width="120" height="48" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="70" y="50" text-anchor="middle" fill="var(--color-flexoki-tx-2)" font-size="11" font-family="ui-monospace, monospace">Web Clipper</text>
    <text x="70" y="66" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">browser extension</text>

    <!-- Arrow: Web Clipper → Inbox -->
    <line x1="130" y1="54" x2="158" y2="54" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- 01_Inbox -->
    <rect x="166" y="30" width="120" height="48" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="226" y="50" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">01_Inbox/</text>
    <text x="226" y="66" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">raw captures</text>

    <!-- Arrow: Inbox → /inbox -->
    <line x1="286" y1="54" x2="318" y2="54" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- /inbox command -->
    <rect x="326" y="30" width="100" height="48" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="376" y="50" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/inbox</text>
    <text x="376" y="66" text-anchor="middle" fill="var(--color-flexoki-bg-2)" font-size="9" font-family="ui-sans-serif, system-ui" opacity="0.7">AI processes</text>

    <!-- Arrow: /inbox → Garden -->
    <line x1="426" y1="54" x2="458" y2="54" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- 03_Garden -->
    <rect x="466" y="30" width="130" height="48" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="531" y="50" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">03_Garden/</text>
    <text x="531" y="66" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">atomic notes</text>

    <!-- Arrow: Garden → /graduate -->
    <line x1="596" y1="54" x2="628" y2="54" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- /graduate command -->
    <rect x="636" y="30" width="110" height="48" rx="8" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="691" y="50" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="13" font-weight="600" font-family="ui-monospace, monospace">/graduate</text>
    <text x="691" y="66" text-anchor="middle" fill="var(--color-flexoki-bg-2)" font-size="9" font-family="ui-sans-serif, system-ui" opacity="0.7">promotes ideas</text>

    <!-- ═══ ROW 2: Output (y=120) ═══ -->

    <!-- Arrow: /graduate ↓ 06_Content -->
    <line x1="691" y1="78" x2="691" y2="112" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- 06_Content -->
    <rect x="626" y="120" width="130" height="48" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="691" y="140" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">06_Content/</text>
    <text x="691" y="156" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">publish-ready</text>

    <!-- ═══ ROW 3: Analysis layer (y=120–220) ═══ -->

    <!-- Arrow: Garden ↓ analysis -->
    <line x1="531" y1="78" x2="531" y2="112" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- Analysis label -->
    <text x="460" y="130" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="10" font-family="ui-sans-serif, system-ui">analysis layer</text>

    <!-- /relink -->
    <rect x="310" y="148" width="100" height="40" rx="6" fill="var(--color-flexoki-bg)" stroke="var(--color-flexoki-ui)" stroke-width="1" stroke-dasharray="4 2" />
    <text x="360" y="172" text-anchor="middle" fill="var(--color-flexoki-tx-2)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">/relink</text>
    <text x="360" y="204" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">finds connections</text>

    <!-- /challenge -->
    <rect x="430" y="148" width="110" height="40" rx="6" fill="var(--color-flexoki-bg)" stroke="var(--color-flexoki-ui)" stroke-width="1" stroke-dasharray="4 2" />
    <text x="485" y="172" text-anchor="middle" fill="var(--color-flexoki-tx-2)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">/challenge</text>
    <text x="485" y="204" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">argues against you</text>

    <!-- /pulse -->
    <rect x="560" y="148" width="90" height="40" rx="6" fill="var(--color-flexoki-bg)" stroke="var(--color-flexoki-ui)" stroke-width="1" stroke-dasharray="4 2" />
    <text x="605" y="172" text-anchor="middle" fill="var(--color-flexoki-tx-2)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">/pulse</text>
    <text x="605" y="204" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">goal alignment</text>

    <!-- ═══ ROW 4: Daily loop (y=260) ═══ -->

    <!-- Daily commands (write to journal) -->
    <rect x="190" y="256" width="80" height="40" rx="6" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="230" y="280" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="12" font-weight="600" font-family="ui-monospace, monospace">/ship</text>

    <rect x="284" y="256" width="72" height="40" rx="6" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="320" y="280" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="12" font-weight="600" font-family="ui-monospace, monospace">/log</text>

    <rect x="370" y="256" width="90" height="40" rx="6" fill="var(--color-flexoki-tx)" stroke="var(--color-flexoki-tx)" stroke-width="1.5" />
    <text x="415" y="280" text-anchor="middle" fill="var(--color-flexoki-bg)" font-size="12" font-weight="600" font-family="ui-monospace, monospace">/today</text>

    <!-- Arrow: commands → Journal -->
    <line x1="190" y1="276" x2="148" y2="276" stroke="var(--color-flexoki-tx-3)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- 02_Journal -->
    <rect x="20" y="252" width="120" height="48" rx="8" fill="var(--color-flexoki-bg-2)" stroke="var(--color-flexoki-ui)" stroke-width="1.5" />
    <text x="80" y="272" text-anchor="middle" fill="var(--color-flexoki-tx)" font-size="12" font-weight="500" font-family="ui-monospace, monospace">02_Journal/</text>
    <text x="80" y="288" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui">daily logs</text>

    <!-- Dashed path: Journal ↑ → Garden (graduate loop) -->
    <path d="M 20 264 L 10 264 L 10 224 L 300 224 L 300 130 L 460 130 L 460 78" stroke="var(--color-flexoki-tx-3)" stroke-width="1" stroke-dasharray="6 3" fill="none" marker-end="url(#arrow)" />
    <text x="155" y="218" text-anchor="middle" fill="var(--color-flexoki-tx-3)" font-size="9" font-family="ui-sans-serif, system-ui" font-style="italic">ideas get /graduated</text>
  </svg>
</div>

<style>
  .knowledge-flow-diagram {
    -webkit-overflow-scrolling: touch;
  }
  .knowledge-flow-diagram svg text {
    user-select: none;
  }
</style>
