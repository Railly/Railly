---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 32 32"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>IA Hackathon Peru</title>
    <rect width="32" height="32" rx="4" fill="#0a0a0a"/>
    <rect x="7" y="5" width="3.5" height="18" fill="white"/>
    <rect x="8" y="3.5" width="3" height="3" rx="0.5" fill="#B91C2C"/>
    <path d="M15 23L21.5 5H25.5L32 23H28L26.5 18.5H20.5L19 23H15ZM21.5 15.5H25.5L23.5 9L21.5 15.5Z" fill="white"/>
</svg>
