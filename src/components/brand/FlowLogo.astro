---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>Flow</title>
    <rect x="2" y="4" width="6" height="4" rx="1" fill="currentColor"/>
    <rect x="9" y="10" width="6" height="4" rx="1" fill="currentColor"/>
    <rect x="16" y="4" width="6" height="4" rx="1" fill="currentColor"/>
    <rect x="16" y="16" width="6" height="4" rx="1" fill="currentColor"/>
    <path d="M8 6h2.5a1 1 0 0 1 1 1v4" stroke="currentColor" stroke-width="1.5"/>
    <path d="M15 12h2.5a1 1 0 0 0 1-1V8" stroke="currentColor" stroke-width="1.5"/>
    <path d="M15 12h2.5a1 1 0 0 1 1 1v4" stroke="currentColor" stroke-width="1.5"/>
</svg>
