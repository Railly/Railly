---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>SkillKit</title>
    <rect x="3" y="14" width="3" height="7" rx="0.5" fill="currentColor" />
    <rect x="8" y="10" width="3" height="11" rx="0.5" fill="currentColor" />
    <rect x="13" y="6" width="3" height="15" rx="0.5" fill="currentColor" />
    <rect x="18" y="3" width="3" height="18" rx="0.5" fill="currentColor" />
</svg>
