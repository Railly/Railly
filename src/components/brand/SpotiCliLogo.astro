---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>spoti-cli</title>
    <circle cx="12" cy="12" r="11" fill="#1DB954"/>
    <path d="M7 10c2.5-1 6-1 9 .8" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M8 13c2-0.8 5-0.8 7.5 .5" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M9 16c1.5-0.6 4-0.6 5.5 .3" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
</svg>
