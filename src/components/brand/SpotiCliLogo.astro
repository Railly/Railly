---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>spoti-cli</title>
    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" />
    <path d="M8 9.5c2.5-1 5.5-1 8 .5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    <path d="M9 12.5c2-0.8 4.5-0.8 6.5.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    <path d="M10 15.5c1.5-0.6 3.5-0.6 5 .2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
</svg>
