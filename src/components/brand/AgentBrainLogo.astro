---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>Agent Brain</title>
    <path
        d="M12 2a7 7 0 0 0-7 7c0 2.5 1.5 4.5 3 6v2a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2c1.5-1.5 3-3.5 3-6a7 7 0 0 0-7-7Z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    />
    <path d="M9 19v1a3 3 0 0 0 6 0v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    <path d="M12 2v7M8 6l4 3 4-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
</svg>
