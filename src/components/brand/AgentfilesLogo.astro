        d="M14 2v6h6"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    />
    <circle cx="10" cy="15" r="1.5" fill="currentColor" />
    <circle cx="14" cy="13" r="1.5" fill="currentColor" />
