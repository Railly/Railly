---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>Codex Globe</title>
    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" />
    <ellipse cx="12" cy="12" rx="4" ry="10" stroke="currentColor" stroke-width="1.5" />
    <path d="M2 12h20" stroke="currentColor" stroke-width="1.5" />
    <path d="M4 7h16M4 17h16" stroke="currentColor" stroke-width="1" opacity="0.5" />
</svg>
