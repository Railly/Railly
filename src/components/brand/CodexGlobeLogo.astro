---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 32 32"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>Codex Globe</title>
    <rect width="32" height="32" rx="6" fill="#0a0a0a"/>
    <circle cx="10" cy="8" r="2" fill="#22c55e"/>
    <circle cx="22" cy="12" r="1.5" fill="#22c55e"/>
    <circle cx="14" cy="20" r="2.5" fill="#22c55e"/>
    <circle cx="24" cy="24" r="1.5" fill="#22c55e"/>
    <circle cx="8" cy="25" r="1" fill="#22c55e"/>
    <circle cx="20" cy="6" r="1" fill="#22c55e"/>
</svg>
