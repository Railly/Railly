---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>Hypeman</title>
    <path
        d="M2 14l6-6 4 4 6-6"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    />
    <path
        d="M15 6h3v3"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    />
    <path
        d="M4 18h16"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
    />
    <circle cx="20" cy="6" r="2" fill="currentColor" />
</svg>
