---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 32 32"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>sunat-cli</title>
    <rect width="32" height="32" rx="6.4" fill="#1A3567"/>
    <text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" font-family="system-ui, -apple-system, sans-serif" font-size="14.4" font-weight="700" fill="#FFFFFF">
        S<tspan fill="#C41E3A">/</tspan>
    </text>
</svg>
