---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 48 48"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>trx</title>
    <rect width="48" height="48" rx="8" fill="#2563EB"/>
    <text x="24" y="20" text-anchor="middle" font-family="monospace" font-size="11" font-weight="700" fill="#F8FAFC" opacity="0.5">///</text>
    <text x="24" y="34" text-anchor="middle" font-family="monospace" font-size="16" font-weight="700" fill="#F8FAFC">trx</text>
</svg>
