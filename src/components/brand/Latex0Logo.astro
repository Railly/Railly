---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 32 32"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>latex0</title>
    <rect width="32" height="32" rx="6" fill="#0a0a0a"/>
    <text x="16" y="22" text-anchor="middle" font-family="'Times New Roman', serif" font-size="16" fill="#fafafa">L<tspan font-size="11" dy="-2">A</tspan><tspan font-size="16" dy="2">0</tspan></text>
</svg>
