---
interface Props {
	width?: number;
	height?: number;
	class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
    width={width}
    height={height}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
>
    <title>Roast Roulette</title>
    <path
        d="M12 22c-4 0-7-2-7-5 0-4 3-5.5 4-9h6c1 3.5 4 5 4 9 0 3-3 5-7 5Z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    />
    <path
        d="M9 8c-.5-2 .5-4 2-5.5C11 4 11.5 5 12 6c.5-1 1-2 1-3.5 1.5 1.5 2.5 3.5 2 5.5"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    />
</svg>
