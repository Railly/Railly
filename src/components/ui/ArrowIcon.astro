---
interface Props {
	size?: number;
	class?: string;
}

const { size = 14, class: className } = Astro.props;
---

<svg
	width={size}
	height={size}
	fill="none"
	stroke="currentColor"
	stroke-width="1.5"
	viewBox="0 0 24 24"
	stroke-linecap="round"
	stroke-linejoin="round"
	xmlns="http://www.w3.org/2000/svg"
	class={className}
>
	<path d="M4.5 12h15m0 0-5.625-6m5.625 6-5.625 6" />
</svg>
