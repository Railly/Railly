---
import type { ColorName } from "@/lib/colors";
import ArrowIcon from "./ArrowIcon.astro";
import Card from "./Card.astro";
import CardIcon from "./CardIcon.astro";

interface Props {
	title: string;
	description: string;
	color: ColorName;
	href?: string;
	icon?: any;
	iconPadding?: string;
	isImage?: boolean;
	imageSrc?: string;
	imageAlt?: string;
}

const {
	title,
	description,
	color,
	href,
	icon,
	iconPadding = "p-3",
	isImage = false,
	imageSrc,
	imageAlt,
} = Astro.props;
---

<Card href={href} color={color}>
  <div class="flex items-start gap-3">
    <CardIcon color={color} padding={iconPadding}>
      {isImage ? (
        <img
          src={imageSrc}
          alt={imageAlt}
          class="w-full h-full object-cover"
        />
      ) : (
        <slot name="icon" />
      )}
    </CardIcon>
    <div class={href ? "flex-grow" : ""}>
      {href && (
        <div class="flex items-center justify-between">
          <h3
            class={`text-foreground font-medium group-hover:text-${color} transition-colors`}
          >
            {title}
          </h3>
          <ArrowIcon class="text-foreground-3 group-hover:translate-x-1 transition-transform" size={16} />
        </div>
      )}
      {!href && (
        <h3
          class={`text-foreground font-medium group-hover:text-${color} transition-colors`}
        >
          {title}
        </h3>
      )}
      <p class="text-xs text-foreground-2 !m-0">
        {description}
      </p>
    </div>
  </div>
</Card>
