# Vercel KV — view counts, claps, draft comments
# Get these from the Vercel KV dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Resend — newsletter subscribe + broadcasts
RESEND_API_KEY=
RESEND_SEGMENT_ID=

# Auth secrets — REQUIRED in production; endpoints fail closed without them
# Generate with: openssl rand -hex 32
NEWSLETTER_API_SECRET=
CRON_SECRET=
DRAFT_SECRET=

# Vercel deploy hook URL — used by /api/cron/rebuild
VERCEL_DEPLOY_HOOK=
